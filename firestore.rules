rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Block all unauthenticated access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Users can only read their own profile
    match /users/{uid} {
      allow read: if request.auth.uid == uid;
    }

    // Submissions: owner reads all, supervisor writes own shed only
    match /submissions/{docId} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["owner", "auditor", "ca"];
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "supervisor";
    }

    // STD table: all authenticated users can read
    match /std_table/{doc} {
      allow read: if request.auth != null;
    }
  }
}
